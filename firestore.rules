rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Basic check: Allow the specific user email or if UID exists in /admins collection
      return isSignedIn() && (
        request.auth.token.email.lower() == 'puskardasofficial@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if false; // Admins are immutable for simplicity, or restricted
    }

    match /users/{uid} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && (
        request.resource.data.adminId == request.auth.uid &&
        request.resource.data.timestamp == request.time
      );
      allow update, delete: if false;
    }
  }
}
