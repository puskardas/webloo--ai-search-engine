rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email.lower() == 'puskardasofficial@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Entities
    match /admins/{uid} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      allow update: if false;
    }

    match /users/{uid} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'lastLogin']) &&
               data.uid == uid &&
               data.email is string &&
               data.displayName is string &&
               data.photoURL is string;
      }
      allow read: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid) && isValidUser(incoming());

      // Search History subcollection
      match /search_history/{historyId} {
        function isValidSearchHistory(data) {
          return data.keys().hasAll(['userId', 'query', 'timestamp', 'type']) &&
                 data.userId == uid &&
                 data.query is string && data.query.size() > 0 && data.query.size() <= 1000 &&
                 data.type in ['text', 'image'] &&
                 data.timestamp == request.time;
        }
        allow list, get: if isOwner(uid);
        allow create: if isOwner(uid) && isValidSearchHistory(incoming());
        allow update: if false; // History entries are usually immutable
        allow delete: if isOwner(uid);
      }
    }

    match /audit_logs/{logId} {
      function isValidAuditLog(data) {
        return data.keys().hasAll(['adminId', 'adminEmail', 'action', 'timestamp']) &&
               data.adminId == request.auth.uid &&
               data.timestamp == request.time;
      }
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidAuditLog(incoming());
      allow update, delete: if false;
    }
  }
}
